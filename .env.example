# ─────────────────────────────────────────────
# REQUIRED — must be set before launching the FastAPI server
#   uv run uvicorn app.api.main:api --reload --host 0.0.0.0 --port 8080
# ─────────────────────────────────────────────

# Your GCP project ID (no quotes, no spaces)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI endpoint for gemini-3.6-flash.
# gemini-3.6-flash availability: global (verified 2026-07-22), us, eu  (NOT asia-northeast1 or us-central1)
# - "global" — multi-region, broadest availability  ← recommended default
# - "us"     — US multi-region
# - "eu"     — EU multi-region
# This is INDEPENDENT of the Cloud Run / GCS region (which is asia-northeast1 for this project).
VERTEX_AI_LOCATION=global

# Cloud Storage bucket for market-data + LLM-response cache.
# Convention: gs://nami-cache-<project-id>  →  use BARE name (no gs:// prefix).
# Create in asia-northeast1 to match Cloud Run for low-latency reads:
#   gsutil mb -l asia-northeast1 gs://nami-cache-<project-id>
GCS_BUCKET=nami-cache-your-gcp-project-id

# Absolute path to your service-account JSON file (LOCAL DEV ONLY).
# On Cloud Run this is provided automatically via the attached service account — do NOT set there.
# Generic example:
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/nami-sa.json
# Windows example: C:/Users/<you>/.gcp/nami-sa.json   (forward slashes work; or escape with \\)

# ─────────────────────────────────────────────
# OPTIONAL — uncomment to override defaults
# ─────────────────────────────────────────────

# Gemini model id (default: gemini-3.6-flash)
# VERTEX_MODEL_ID=gemini-3.6-flash

# Per-1M-token Vertex list prices used by the daily-budget breaker (estimation
# only, not billing). Defaults match gemini-3.6-flash standard tier (2026-07-22);
# output price covers response + thinking tokens. Update on Google repricing.
# PRICE_INPUT_PER_MTOK=1.50
# PRICE_OUTPUT_PER_MTOK=7.50

# Daily paid-LLM breakers: max scenario runs and max estimated spend per UTC day.
# DAILY_LLM_RUN_CAP=500
# DAILY_LLM_COST_CAP_USD=25.0

# LLM temperature (default: 0 — reproducibility per README)
# LLM_TEMPERATURE=0

# Market-data cache TTL in hours (default: 24)
# MARKET_DATA_CACHE_TTL_HOURS=24

# LLM-response cache TTL in days (default: 7)
# LLM_CACHE_TTL_DAYS=7

# Factor regression beta lookback in weeks (default: 156 = 3y)
# BETA_LOOKBACK_WEEKS=156

# Ridge regularization alpha for factor regression (default: 0.1).
# Applies in standardized unit-variance factor units (homogeneous shrinkage
# across factors). Changing it self-invalidates the scenario cache via the
# regression_spec key component — no PROMPT_VERSION bump needed.
# RIDGE_ALPHA=0.1

# Narrative-Shapley pool size. 2^N−1 independent run_scenario calls are submitted
# to a ThreadPoolExecutor; lower this to 2 if Gemini rate-limits show up (default: 4).
# NARRATIVE_SHAPLEY_MAX_WORKERS=4

# Logging verbosity (default: INFO; use DEBUG for troubleshooting)
# LOG_LEVEL=INFO

# Environment label (default: dev; values: dev | staging | prod)
# ENVIRONMENT=dev

# Admin unlock passcode for local development.
# In Cloud Run this is injected from Secret Manager as nami-passcode:latest.
# PASSCODE=replace-with-a-long-random-passcode
